⚡ Core TypeScript Logic
1. Lichess Arena Importer Logic (src/lib/lichess.ts)
TypeScript
import { supabase } from './supabase';
import { calculateElo } from './elo';

export interface ArenaImportReport {
  processedGames: number;
  skippedUnlinkedGames: number;
  unlinkedUsernames: string[];
}

export async function importLichessArena(
  arenaId: string, 
  eventName: string
): Promise<ArenaImportReport> {
  // 1. Stream tournament games from Lichess API (NDJSON)
  const res = await fetch(`[https://lichess.org/api/tournament/$](https://lichess.org/api/tournament/$){arenaId}/games`, {
    headers: { Accept: 'application/x-ndjson' },
  });

  if (!res.ok) throw new Error('Failed to retrieve Lichess Arena data.');

  const text = await res.text();
  const rawGames = text.trim().split('\n').filter(Boolean).map((line) => JSON.parse(line));

  // 2. Load registered FCA profiles (skipping immortalized profiles)
  const { data: profiles, error } = await supabase
    .from('profiles')
    .select('id, lichess_username, blitz_elo, blitz_games, is_immortal')
    .eq('is_immortal', false);

  if (error || !profiles) throw new Error('Failed to load FCA member profiles.');

  const profileMap = new Map(
    profiles
      .filter((p) => p.lichess_username)
      .map((p) => [p.lichess_username!.toLowerCase(), p])
  );

  const report: ArenaImportReport = {
    processedGames: 0,
    skippedUnlinkedGames: 0,
    unlinkedUsernames: [],
  };

  const unlinkedSet = new Set<string>();

  // 3. Process completed games
  for (const game of rawGames) {
    const whiteHandle = game.players.white.user?.name?.toLowerCase();
    const blackHandle = game.players.black.user?.name?.toLowerCase();

    if (!whiteHandle || !blackHandle) continue;

    const whiteProfile = profileMap.get(whiteHandle);
    const blackProfile = profileMap.get(blackHandle);

    // Skip games if either player is unlinked or immortalized
    if (!whiteProfile || !blackProfile) {
      report.skippedUnlinkedGames++;
      if (!whiteProfile) unlinkedSet.add(whiteHandle);
      if (!blackProfile) unlinkedSet.add(blackHandle);
      continue;
    }

    let scoreWhite = 0.5;
    if (game.winner === 'white') scoreWhite = 1.0;
    else if (game.winner === 'black') scoreWhite = 0.0;

    // K-factor: 40 for provisional (< 15 games), 20 for established
    const kWhite = whiteProfile.blitz_games < 15 ? 40 : 20;
    const kBlack = blackProfile.blitz_games < 15 ? 40 : 20;

    const { newA, newB } = calculateElo(
      whiteProfile.blitz_elo,
      blackProfile.blitz_elo,
      scoreWhite,
      kWhite,
      kBlack
    );

    // Record game entry
    await supabase.from('games').insert({
      white_player_id: whiteProfile.id,
      black_player_id: blackProfile.id,
      mode: 'BLITZ',
      result: scoreWhite,
      source: 'LICHESS_ARENA',
      event_name: eventName,
    });

    // Update player ratings
    await supabase.from('profiles').update({
      blitz_elo: newA,
      blitz_games: whiteProfile.blitz_games + 1,
    }).eq('id', whiteProfile.id);

    await supabase.from('profiles').update({
      blitz_elo: newB,
      blitz_games: blackProfile.blitz_games + 1,
    }).eq('id', blackProfile.id);

    report.processedGames++;
  }

  report.unlinkedUsernames = Array.from(unlinkedSet);
  return report;
}
